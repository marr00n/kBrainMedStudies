ource: [source description — e.g. \"Dr Smith, Grand Round presentation, March 2026\"]*"}]}},"version":2,"versionNonce":55449064,"index":"al","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"updated":1777041056534,"locked":false},{"id":"5l06kcoud64qi9fyrpdle","type":"text","x":3677.6,"y":4247.5,"width":264,"height":25,"angle":0,"strokeColor":"#4A148C","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","opacity":100,"roundness":null,"originalText":"[code_fence]","text":"[code_fence]","fontSize":20,"fontFamily":5,"textAlign":"center","verticalAlign":"middle","containerId":"qxsnf2446ubiy5k3mco9h","autoResize":true,"lineHeight":1.25,"lineCount":1,"version":2,"versionNonce":817142936,"index":"am","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"boundElements":[],"updated":1777041056534,"link":null,"locked":false},{"id":"tw28y3fr7vqher3oxel68","type":"arrow","x":2896.7999999999997,"y":4260,"width":612.8000000000002,"height":0,"angle":0,"strokeColor":"#6A1B9A","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.2,"strokeStyle":"dashed","opacity":100,"roundness":null,"points":[[0,0],[612.8000000000002,0]],"startBinding":{"elementId":"i52t5n640hixrhaqqw9lyc","focus":0.5,"gap":4,"fixedPoint":[1,0.5001],"mode":"orbit"},"endBinding":{"elementId":"qxsnf2446ubiy5k3mco9h","focus":0.5,"gap":4,"fixedPoint":[0,0.5001],"mode":"orbit"},"startArrowhead":null,"endArrowhead":"arrow","elbowed":true,"version":2,"versionNonce":1474500840,"index":"an","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"boundElements":[],"updated":1777041056534,"link":null,"locked":false,"fixedSegments":null},{"id":"82qj7ain5tpd2syamkxaa","type":"rectangle","x":2447.2,"y":4627.5,"width":942.4000000000001,"height":145,"angle":0,"strokeColor":"#F9A825","backgroundColor":"#FFF8E1","fillStyle":"solid","strokeWidth":2.1,"strokeStyle":"solid","opacity":100,"roundness":{"type":3},"boundElements":[{"typ