d":null,"boundElements":[],"updated":1777041056535,"link":null,"locked":false},{"id":"q9bi96kgr23srscu6d33j","type":"arrow","x":2327.2,"y":7780,"width":120,"height":440,"angle":0,"strokeColor":"#F9A825","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1.4,"strokeStyle":"solid","opacity":100,"roundness":null,"points":[[0,0],[60,0],[60,-440],[120,-440]],"startBinding":{"elementId":"ecqzk53kwb8exje2qs24dn","focus":0.5,"gap":4,"fixedPoint":[1,0.5001],"mode":"orbit"},"endBinding":{"elementId":"3vllm6isr9damkbuv345mf","focus":0.5,"gap":4,"fixedPoint":[0,0.5001],"mode":"orbit"},"startArrowhead":null,"endArrowhead":"arrow","elbowed":true,"version":2,"versionNonce":1836140008,"index":"b0H","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"boundElements":[],"updated":1777041056535,"link":null,"locked":false,"fixedSegments":null},{"id":"sg65ibw50z829o49fxymyp","type":"embeddable","x":2447.2,"y":7580,"width":600,"height":400,"angle":0,"strokeColor":"#F9A825","backgroundColor":"#FFF8E1","fillStyle":"solid","strokeWidth":2.1,"strokeStyle":"solid","opacity":100,"roundness":{"type":3},"boundElements":[{"type":"arrow","id":"038ldcv80302b2odxxl56bo"},{"type":"text","id":"iujiqy1tk3cxabiw9oxxpb"}],"link":"demo.md","customData":{"jsonValue":{"type":"ordered_list","attrs":{"order":1},"content":[{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Extract the clinical bottom line first."},{"type":"text","text":" What does the anaesthetist need to know and do?"}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Strip teaching scaffolding."},{"type":"text","text":" Remove \"Today we're going to talk about...\", \"As you can see...\", \"This is really important because...\"."}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Collapse repetition."},{"type":"text","text":" If a point is made three ways, state it once."}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Convert prose to bullets."},{"type":"text","text":" Anything that can be a bullet, should be."}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Replace verbose phrases with symbols"},{"type":"text","text":" (↑ ↓ → ± ≥ ≤, 2° to, etc.)."}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Preserve numerical precision."},{"type":"text","text":" Doses, thresholds, measurements — keep them exact."}]}]},{"type":"list_item","attrs":{"isCollapsed":false},"content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"strong"}],"text":"Maintain clinical nuance."},{"type":"text","text":" \"Consider\" vs \"always\" — preserve the distinction."}]}]}]}},"version":2,"versionNonce":1369205912,"index":"b0I","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"updated":1777041056535,"locked":false},{"id":"iujiqy1tk3cxabiw9oxxpb","type":"text","x":2608.6,"y":7745,"width":277.20000000000005,"height":70,"angle":0,"strokeColor":"#E65100","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","opacity":100,"roundness":null,"originalText":"[ordered_list]","text":"[ordered_\nlist]","fontSize":28,"fontFamily":5,"textAlign":"center","verticalAlign":"middle","containerId":"sg65ibw50z829o49fxymyp","autoResize":true,"lineHeight":1.25,"lineCount":2,"version":2,"versionNonce":1981827304,"index":"b0J","isDeleted":false,"roughness":1,"seed":1,"groupIds":[],"frameId":null,"boundElements":[],"updated":1777041056535,"link":null,"locked":false},{"id":"038ldcv